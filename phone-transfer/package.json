{
  "name": "phone-transfer",
  "version": "1.0.0",
  "description": "局域网手机文件传输工具 - 扫码即传",
  "main": "server.js",
  "bin": "server.js",
  "scripts": {
    "start": "node server.js",
    "build:win": "pkg . --targets node18-win-x64 --output dist/win/phone-transfer.exe",
    "build:mac": "pkg . --targets node18-macos-x64 --output dist/mac/phone-transfer",
    "build:mac-arm": "pkg . --targets node18-macos-arm64 --output dist/mac-arm/phone-transfer",
    "build:all": "npm run build:win && npm run build:mac && npm run build:mac-arm"
  },
  "pkg": {
    "assets": [
      "public/**/*"
    ],
    "outputPath": "dist"
  },
  "dependencies": {
    "express": "^4.18.2",
    "multer": "^1.4.5-lts.1",
    "qrcode": "^1.5.3",
    "qrcode-terminal": "^0.12.0"
  },
  "devDependencies": {
    "@yao-pkg/pkg": "^5.11.0"
  }
}
